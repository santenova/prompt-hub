{
  "name": "Prompt",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Title or name of the prompt"
    },
    "content": {
      "type": "string",
      "description": "The actual prompt text"
    },
    "category": {
      "type": "string",
      "enum": [
        "Writing",
        "Coding",
        "Business",
        "Creative",
        "Marketing",
        "Research",
        "Education",
        "Relations",
        "Personas",
        "Health & Wellness",
        "Finance & Investment",
        "Legal",
        "Productivity",
        "Sales",
        "Design",
        "Gaming",
        "Food & Cooking",
        "Travel & Lifestyle",
        "Career Development",
        "Personal Development",
        "Data & Analytics",
        "AI & Machine Learning",
        "Social Media",
        "E-commerce",
        "Other"
      ],
      "default": "Other",
      "description": "Category of the prompt"
    },
    "subcategory": {
      "type": "string",
      "description": "Subcategory for more specific classification"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Tags for the prompt"
    },
    "is_favorite": {
      "type": "boolean",
      "default": false,
      "description": "Whether the prompt is marked as favorite"
    },
    "use_count": {
      "type": "number",
      "default": 0,
      "description": "Number of times the prompt has been used"
    },
    "rating": {
      "type": "number",
      "default": 0,
      "description": "Average rating (1-5 stars)"
    },
    "rating_count": {
      "type": "number",
      "default": 0,
      "description": "Number of ratings received"
    },
    "user_ratings": {
      "type": "object",
      "description": "Object storing individual user ratings with email as key",
      "default": {}
    }
  },
  "required": [
    "title",
    "content",
    "category"
  ]
}